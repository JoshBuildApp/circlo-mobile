# -----------------------------------------------------------------------
# Circlo Mobile — .gitignore
# -----------------------------------------------------------------------

# Deps & build
node_modules
dist
dist-ssr
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Env
.env
.env.*.local

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------
# Capacitor / iOS / Android
# -----------------------------------------------------------------------

# iOS — we commit the Xcode project but not build artifacts
ios/App/build/
ios/App/Pods/
ios/App/Podfile.lock
ios/DerivedData/
ios/App/App/public/
ios/App/output/
xcuserdata/
*.xcuserstate

# Android — we commit gradle wrapper but not build artifacts
android/.gradle/
android/build/
android/app/build/
android/app/release/
android/capacitor-cordova-android-plugins/
android/local.properties
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
*.iml
.gradle/

# Capacitor runtime files (regenerated by `cap sync`)
android/app/src/main/assets/public/

# APNs / FCM push credentials — never commit
*.p8
secrets/
supabase/secrets/
